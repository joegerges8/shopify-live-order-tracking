# Server
PORT=3000
APP_URL=https://your-live-dispatch-domain.example.com

# Auth (required for driver login/signup)
JWT_SECRET=change-me-to-a-long-random-string

# Postgres (local)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=shopify_live_tracking
DB_USER=postgres
DB_PASSWORD=password

# Shopify webhook verification
SHOPIFY_CLIENT_ID=your-shopify-app-client-id
SHOPIFY_CLIENT_SECRET=your-shopify-app-client-secret
SHOPIFY_API_VERSION=2026-04
